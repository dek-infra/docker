# ------------------------------------------
# ClickHouse Configuration
# ------------------------------------------
# The hostname or IP where ClickHouse is running
CLICKHOUSE_HOST=<your_clickhouse_host>
# HTTP Port for ClickHouse (default: 8123)
CLICKHOUSE_PORT=<your_clickhouse_port>
# TCP Port for ClickHouse native client (default: 9000)
CLICKHOUSE_TCP_PORT=<optional_clickhouse_tcp_port>
# Initial database to create on startup
CLICKHOUSE_DB=<predefined_clickhouse_db>
# ClickHouse Admin credentials
CLICKHOUSE_USER=<your_clickhouse_username>
CLICKHOUSE_PASSWORD=<your_clickhouse_password>
# Enable access management via SQL (Required for backups)
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1

# ------------------------------------------
# MinIO (S3 Storage) Configuration
# ------------------------------------------
# The hostname or IP where MinIO is running
MINIO_HOST=<your_minio_host>
# API Port for S3 operations (default: 9000)
MINIO_PORT=<your_minio_port>
# Port for MinIO Web UI Console (default: 9001)
MINIO_CONSOLE_PORT=<your_minio_console_port>
# MinIO Admin credentials (used for S3 access key)
MINIO_ROOT_USER=<your_root_user>
MINIO_ROOT_PASSWORD=<your_root_password>
# Default bucket name to store ClickHouse backups
MINIO_BUCKET_NAME=<predefined_minio_bucket>

# ------------------------------------------
# n8n (Automation) Configuration
# ------------------------------------------
# n8n interface settings
N8N_HOST=<your_n8n_host>
N8N_PORT=<your_n8n_port>
N8N_PROTOCOL=<n8n_protocol>
# Webhook URL for external triggers (if any)
WEBHOOK_URL=<n8n_webhook_url>
# Timezone for n8n cron schedules (e.g., Asia/Bangkok)
GENERIC_TIMEZONE=<timezone>